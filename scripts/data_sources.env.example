# Copy this file to .env.data at repository root, then fill your values.

# NOAA Climate Data Online API token (required for NOAA commands)
NOAA_TOKEN=YOUR_NOAA_TOKEN

# U.S. Census API key (optional but recommended)
CENSUS_KEY=YOUR_CENSUS_KEY

# Transitland API key (required for Transitland commands)
TRANSITLAND_API_KEY=YOUR_TRANSITLAND_API_KEY

# Optional NOAA settings
NOAA_STATION_ID=GHCND:USW00024233
NOAA_START_DATE=2024-01-01
NOAA_END_DATE=2024-12-31
NOAA_DATATYPES="PRCP TMAX TMIN AWND"

# Optional ACS settings
ACS_YEAR=2023
ACS_STATE_FIPS=53
ACS_COUNTY_FIPS=033
ACS_GET_VARS=NAME,B01001_001E

# Optional Transitland settings
TRANSITLAND_FEED_ID=f-c23-metrokingcounty
TRANSITLAND_LIMIT=20
