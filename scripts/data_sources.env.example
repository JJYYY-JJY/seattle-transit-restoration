# Copy this file to .env.data at repository root, then fill your values.

# NOAA Climate Data Online API token (required for NOAA commands)
NOAA_TOKEN=YOUR_NOAA_TOKEN

# U.S. Census API key (optional but recommended)
CENSUS_KEY=YOUR_CENSUS_KEY

# Transitland API key (required for Transitland commands)
TRANSITLAND_API_KEY=YOUR_TRANSITLAND_API_KEY

# Optional GTFS-RT API key for real-time feeds (if provider requires auth)
GTFSRT_API_KEY=
GTFSRT_API_KEY_HEADER=x-api-key
GTFSRT_BEARER_TOKEN=

# GTFS-RT feed URLs (set at least one for 24x7 real-time capture)
GTFSRT_TRIP_UPDATES_URL=
GTFSRT_VEHICLE_POSITIONS_URL=
GTFSRT_ALERTS_URL=

# Optional NOAA settings
NOAA_STATION_ID=GHCND:USW00024233
NOAA_START_DATE=2024-01-01
NOAA_END_DATE=2024-12-31
NOAA_DATATYPES="PRCP TMAX TMIN AWND"

# Optional ACS settings
ACS_YEAR=2023
ACS_STATE_FIPS=53
ACS_COUNTY_FIPS=033
ACS_GET_VARS=NAME,B01001_001E

# Optional Transitland settings
TRANSITLAND_FEED_ID=f-c23-metrokingcounty
TRANSITLAND_LIMIT=20

# Optional 24x7 updater schedule tuning
UPDATER_GTFSRT_INTERVAL_SECONDS=30
UPDATER_KCM_STATIC_INTERVAL_MINUTES=360
UPDATER_TRANSITLAND_VERSIONS_INTERVAL_MINUTES=720
UPDATER_TRANSITLAND_LATEST_INTERVAL_MINUTES=1440
UPDATER_NOAA_INTERVAL_MINUTES=360
UPDATER_NOAA_LOOKBACK_DAYS=7
UPDATER_ACS_INTERVAL_HOURS=168
UPDATER_FAILURE_RETRY_SECONDS=300
UPDATER_ACS_YEAR=auto
